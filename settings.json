{
  "includeCoAuthoredBy": false,
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre_tool_use.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/ensure_context_loaded.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validation_gate.py",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce_rpi_workflow.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/progress_checkpoint.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/file_size_check.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/interactive_decision.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/reality_checkpoint.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post_tool_use.py",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop.py",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent_stop.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "^DISABLED$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notification.py --notify",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  }
}
